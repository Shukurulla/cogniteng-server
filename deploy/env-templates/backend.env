# Copy to backend/.env on the server, then fill in real secrets.

NODE_ENV=production
PORT=9817

# MongoDB (with auth — note authSource=admin for root user)
MONGODB_URI=mongodb://root:CHANGE_ME@127.0.0.1:27017/cogniteng?authSource=admin

# Generate strong random secrets, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=CHANGE_ME_with_64+_random_chars
JWT_REFRESH_SECRET=CHANGE_ME_with_64+_random_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# Comma-separated allowed origins (no trailing slash).
# Add your frontend's URL here once it's hosted (Vercel, Netlify, separate domain, etc.).
# Use * for development only — never in production.
CORS_ORIGIN=https://your-frontend-domain.example
